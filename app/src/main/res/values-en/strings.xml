    <!-- Privacy Policy Dialog -->
    <string name="privacy_title">Privacy Policy</string>
    <string name="privacy_intro">척척 가계부 values and protects your privacy.</string>
    <string name="privacy_section_collect">1. Information Collected</string>
    <string name="privacy_collect_detail">\u0020\u0020• SMS messages (for payment parsing)\n\u0020\u0020• Monthly income and budget settings\n\u0020\u0020• Google account email (when using Drive backup)\n\u0020\u0020• Device and app usage data for ads, analytics, and crash diagnostics</string>
    <string name="privacy_section_usage">2. Purpose of Use</string>
    <string name="privacy_usage_detail">\u0020\u0020• Automatic expense/income tracking\n\u0020\u0020• AI-based category classification (Gemini API)\n\u0020\u0020• Cloud backup and restore\n\u0020\u0020• Ad delivery and app quality improvement</string>
    <string name="privacy_section_storage">3. Data Storage</string>
    <string name="privacy_storage_detail">\u0020\u0020• Transaction data is stored locally on your device\n\u0020\u0020• Google Drive backups are stored in your own Drive\n\u0020\u0020• We do not store personal data on our servers</string>
    <string name="privacy_section_thirdparty">4. Third-Party Sharing</string>
    <string name="privacy_thirdparty_detail">\u0020\u0020• Store names, amounts, transaction context, or masked message snippets may be sent to Google Gemini API for AI classification and advice\n\u0020\u0020• Direct identifiers such as phone numbers are removed or minimized where possible\n\u0020\u0020• Google AdMob and Firebase SDKs may process device and app usage data for ads, analytics, and crash diagnostics\n\u0020\u0020• We do not sell personal data or share it beyond the disclosed purposes</string>
    <string name="privacy_section_rights">5. Your Rights</string>
    <string name="privacy_rights_detail">\u0020\u0020• You can delete all data at any time from Settings\n\u0020\u0020• Uninstalling the app removes all local data</string>
    <string name="privacy_last_updated">Last updated: April 25, 2026</string>

